# ===========================================
# 环境变量模板
# 复制此文件为 .env 并修改对应值
# ===========================================

# 服务器端口
PORT=4000

# Node 环境
NODE_ENV=development

# ===========================================
# API 配置（生产环境需要修改为实际地址）
# ===========================================

# 一般 API 地址（REST API）
NUXT_PUBLIC_API_BASE=http://localhost:3001/api

# 上传文件专用 API
NUXT_PUBLIC_API_UPLOAD=http://localhost:3001/api/upload
